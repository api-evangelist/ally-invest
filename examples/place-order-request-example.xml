<?xml version="1.0" encoding="UTF-8"?>
<!-- Example FIXML order request: Buy 10 shares of AAPL at market price -->
<FIXML xmlns="http://www.fixprotocol.org/FIXML-5-0-SP2">
  <Order
    TmInForce="0"
    Typ="1"
    Side="1"
    Acct="12345678">
    <Instrmt
      SecTyp="CS"
      Sym="AAPL"/>
    <OrdQty
      Qty="10"/>
  </Order>
</FIXML>
